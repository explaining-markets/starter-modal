# Explaining Markets starter — environment variables.
#
# These power the deployed app. In production you set them as a Modal Secret
# named "explaining-markets" (see the README); this file is only a reference /
# for local `modal serve` via `--env-file`.

# Required — from your submission's Credentials tab in the portal (shown once).
EM_API_KEY=
EM_WEBHOOK_SECRET=whsec_

# Optional — defaults to the beta API.
EM_API_BASE_URL=https://api-beta.explainingmarkets.ai/v1

# Optional — when OPENAI_API_KEY is set, predict.py makes real LLM calls;
# otherwise it falls back to a 0.5 baseline.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
