# Copy this file to `.env` and fill it in:  cp .env.example .env
# Modal loads `.env` at deploy time, so `modal deploy` picks these up.
# `.env` is gitignored — never commit your real credentials.

# ── Required ── paste these two from your submission's Credentials tab ──
EM_API_KEY=
EM_WEBHOOK_SECRET=whsec_

# ── Optional ── sensible defaults; uncomment only to override ──
# OPENAI_API_KEY makes predict.py do real LLM calls; leave blank for the 0.5 baseline.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-nano
# EM_API_BASE_URL=https://api.explainingmarkets.ai/v1
